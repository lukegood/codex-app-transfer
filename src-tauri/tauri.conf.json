{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex App Transfer",
  "version": "2.4.0",
  "identifier": "store.alyse.codex-app-transfer",
  "build": {
    "frontendDist": "../frontend/dist",
    "beforeDevCommand": "npm --prefix frontend install && npm --prefix frontend run dev",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Codex App Transfer",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "url": "cas://localhost/",
        "width": 800,
        "height": 760,
        "minWidth": 700,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "../macos/entitlements.plist"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["codex-app-transfer"]
      }
    }
  }
}
